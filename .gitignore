.axoCover/*
!.axoCover/settings.json

# Coverlet
coverage*.json
coverage*.xml
coverage*.info

# Web workbench (sass)
.sass-cache/

# Installshield
[Ee]xpress/
*.cab
*.msi
*.msm
*.msp

# Click-Once
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
